## 使用方式
# 复制本文件为项目根目录的 .env.local（勿提交仓库），按需填真实值后重启：npm run dev:api
#
# 与小程序相关的两端配置：
#   · 根目录 .env.local     → server/index.ts（TRTC 签发、百炼出题/ASR、微信、MySQL）
#   · miniapp-candidate/.env.local → TARO_APP_API_BASE 等（改后需重新 npm run dev:weapp）

# ---------------------------------------------------------------------------
# 微信小程序（code2Session 换 openid；login-invite / wechat/login 依赖）
# 微信公众平台 → 开发 → 开发管理 → 开发设置 → AppID / AppSecret
# ---------------------------------------------------------------------------
WECHAT_APPID="YOUR_WECHAT_MINIPROGRAM_APPID"
WECHAT_SECRET="YOUR_WECHAT_MINIPROGRAM_SECRET"

# ---------------------------------------------------------------------------
# 腾讯云实时音视频 TRTC（小程序 live-pusher 进房；UserSig 仅在服务端生成）
# 控制台：https://console.cloud.tencent.com/trtc
#   · SDKAppID：应用管理 → 创建应用后可见（填数字，不要引号里的 0 占位）
#   · 密钥：同一应用 → 快速上手 / 密钥（TRTC_SDK_SECRET_KEY，勿泄露）
# 不配或 SDKAppID=0：/api/candidate/trtc/credential 返回 503，小程序降级为本地 Camera 预览
# ---------------------------------------------------------------------------
TRTC_SDK_APP_ID="1600134495"
TRTC_SDK_SECRET_KEY="c697c5121ba0b35cbb964d3ffb7fe220e7afa42f55a2a5ce26774a4b29763935"
# UserSig 有效期（秒），默认 86400
# TRTC_USER_SIG_EXPIRE_SEC="86400"

# ---------------------------------------------------------------------------
# 阿里云百炼 DashScope（server/index.ts：AI 面试出题 + 可选接口 /api/candidate/ai-interview/asr）
# 控制台：https://bailian.console.aliyun.com/ → API-KEY
# 不配：出题接口失败；ASR 接口返回 503（小程序面试页主路径可用 WechatSI，不依赖此项）
# ---------------------------------------------------------------------------
DASHSCOPE_API_KEY="sk-f1628f34bcd64edcb0b31917159f60aa"
# 可选，默认北京兼容模式 OpenAI 兼容地址
# DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# 出题模型（以控制台可用名为准）
# QWEN_QUESTION_MODEL="qwen3.5-plus"
# 管理端简历 AI 筛查（未设置时沿用 QWEN_QUESTION_MODEL）
# QWEN_RESUME_MODEL="qwen-turbo"
# 语音识别（分段上传 ASR）
# QWEN_ASR_MODEL="qwen3-asr-flash"

# ---------------------------------------------------------------------------
# MySQL（会话、岗位、消息等持久化；健康检查 GET /api/health 会 ping 库）
# ---------------------------------------------------------------------------
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="ai_recruit"
MYSQL_PASSWORD="CHANGE_ME"
MYSQL_DATABASE="ai_recruit"
MYSQL_CONNECTION_LIMIT="10"
# server.ts（npm run dev：Vite + 管理演示）使用的库，需执行 server/schema_admin.sql
MYSQL_ADMIN_DATABASE="ai_recruit_admin"

# ---------------------------------------------------------------------------
# Redis（可选：管理端登录会话存 Redis，键前缀默认 ar:admin:sess:）
# 不配则沿用无状态 HMAC 令牌（需 ADMIN_SESSION_SECRET 或 ADMIN_API_TOKEN）
# 可二选一：REDIS_URL，或 REDIS_HOST + REDIS_PORT + REDIS_PASSWORD + REDIS_DB
# REDIS_URL="redis://:密码@127.0.0.1:6379/0"
# REDIS_HOST="127.0.0.1"
# REDIS_PORT="6379"
# REDIS_PASSWORD=""
# REDIS_DB="0"
# REDIS_ADMIN_SESSION_PREFIX="ar:admin:sess:"

# ---------------------------------------------------------------------------
# 小程序 API 服务（npm run dev:api → server/index.ts）
# ---------------------------------------------------------------------------
# 设为 1 时终端输出 [api] 每条请求摘要、[flow] 候选人关键步骤（不含 /api/health）
# FLOW_LOG="1"
PORT="3001"
HOST="0.0.0.0"
# 管理类接口：Authorization: Bearer <token> 或 X-Admin-Token（与旧版一致，可选）
ADMIN_API_TOKEN="CHANGE_ME_LONG_RANDOM"
#
# 方式 B：环境变量单账号登录（可选；与方式 C 二选一即可）
#   · ADMIN_USERNAME / ADMIN_PASSWORD
#   · 会话：配 Redis（REDIS_*）即可；不配 Redis 时需 ADMIN_SESSION_SECRET 或 ADMIN_API_TOKEN 签发 HMAC 令牌
# ADMIN_USERNAME="admin"
# ADMIN_PASSWORD="CHANGE_ME_STRONG"
# ADMIN_SESSION_SECRET="CHANGE_ME_ANOTHER_LONG_RANDOM"
# ADMIN_SESSION_TTL_SEC="604800"
#
# 方式 C：仅管理库 users 表（username + password_hash），可不配 ADMIN_USERNAME / ADMIN_PASSWORD
#   · 库：MYSQL_ADMIN_DATABASE（默认 ai_recruit_admin），迁移见 server/migration_admin_users_password.sql
#   · 会话：建议 REDIS_*（管理端 session 存 Redis）；无 Redis 时用 ADMIN_SESSION_SECRET 或 ADMIN_API_TOKEN 签 HMAC
#   · 生成哈希：node server/scripts/print-admin-password-hash.mjs '你的密码' → UPDATE users SET password_hash='...' WHERE username='...'

# ---------------------------------------------------------------------------
# 根目录 Vite 管理前端（npm run dev → server.ts），勿与 PORT 混用
# ---------------------------------------------------------------------------
ADMIN_UI_PORT="3000"
ADMIN_UI_HMR_PORT="24679"
# 管理端调小程序 API（npm run dev:api 默认 3001）。开发模式下不配则默认 http://127.0.0.1:3001
# VITE_API_BASE="http://localhost:3001"
# 任选其一：浏览器内登录（见 server 方式 B），或构建期写入静态令牌（与 ADMIN_API_TOKEN 相同）：
# VITE_ADMIN_API_TOKEN="与 ADMIN_API_TOKEN 相同"

# ---------------------------------------------------------------------------
# Docker 部署（docker compose）
# 1) 服务器复制本文件为 .env 并填写密钥；勿把 .env 提交仓库。
# 2) 构建镜像前在 shell 导出（Vite 写入管理端静态资源，须为浏览器可访问的公网地址）：
#    export PUBLIC_API_BASE=https://你的域名或IP:3001
#    export VITE_ADMIN_API_TOKEN_BUILD=与上方 ADMIN_API_TOKEN 相同
#    docker compose build
# 3) 启动：docker compose up -d
# 映射端口可用环境变量 API_PORT、ADMIN_PORT 覆盖默认 3011、3010。
#
# 简历原件「预览 / 下载」：compose 已为 api 挂载命名卷到容器内 /app/storage/resumes（持久化，重建容器不丢）。
#   高级：改用宿主机目录时，改 docker-compose.yml 中 api.volumes 右侧为 /app/storage/resumes，
#   左侧为宿主机路径即可；若把挂载点改成例如 /data/resumes，请在 .env 增加：
#   RESUME_STORAGE_DIR="/data/resumes"
#   须与 compose 挂载的「容器内路径」完全一致，否则上传成功但预览 404。
#
# 管理后台与 API 不同域名时，务必让 admin 容器能注入公网 API 地址（否则前端会请求 localhost:3011）：
#   MINIAPP_API_PUBLIC_URL=https://你的API域名   # 示例 https://apirecruit.cisetech.com
# 若 Nginx 把 /api 反代到 API 且与后台同域，可填与后台相同的主站 https URL。
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# 其他（根目录 Vite demo 等）
# ---------------------------------------------------------------------------
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
